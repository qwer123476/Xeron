local repo = "https://raw.githubusercontent.com/deividcomsono/Obsidian/main/"
local Library = loadstring(game:HttpGet(repo .. "Library.lua"))()

local Options = Library.Options
local Toggles = Library.Toggles

Library.ForceCheckbox = false

-- OrionLib shim (we keep OrionLib.Themes below intact)
local OrionLib = {
	Themes = {},
	Flags = {},
	ThemeObjects = {},
}

do
	setmetatable(OrionLib.Flags, {
		__index = function(t, k)
			local flag = {
				Set = function() end,
				SetValue = function() end,
				Get = function() return nil end,
			}
			rawset(t, k, flag)
			return flag
		end,
	})

	local function safeNotify(title, content, time)
		pcall(function()
			Library:Notify({
				Title = tostring(title or "Notification"),
				Description = tostring(content or ""),
				Time = tonumber(time) or 5,
			})
		end)
	end

	function OrionLib:MakeNotification(info)
		return safeNotify(info and (info.Name or info.Title), info and (info.Content or info.Description), info and info.Time)
	end

	local function getGroup(tabProxy)
		if tabProxy._currentGroup then
			return tabProxy._currentGroup
		end
		-- alternate sides to mimic left/right distribution
		local side = tabProxy._side or 1
		local groupName = (tabProxy._name or "Tab") .. " Main"
		local grp = (side == 1) and tabProxy._tab:AddLeftGroupbox(groupName) or tabProxy._tab:AddRightGroupbox(groupName)
		tabProxy._side = (side == 1) and 2 or 1
		tabProxy._currentGroup = grp
		return grp
	end

	local function makeLabelProxy(lbl)
		return {
			Set = function(_, v)
				pcall(function() lbl:SetText(tostring(v)) end)
			end,
			SetText = function(_, v)
				pcall(function() lbl:SetText(tostring(v)) end)
			end,
		}
	end

	local function makeToggleProxy(t)
		local proxy = {
			_obj = t,
			Set = function(_, v) pcall(function() t:SetValue(v) end) end,
			SetValue = function(_, v) pcall(function() t:SetValue(v) end) end,
			Get = function() return t.Value end,
		}
		setmetatable(proxy, {
			__index = function(_, k)
				return t[k]
			end,
			__newindex = function(_, k, v)
				t[k] = v
			end,
		})
		return proxy
	end

	local function makeDropdownProxy(d)
		if type(d) ~= "table" then
			return d
		end
		d.Set = function(_, v)
			pcall(function() d:SetValue(v) end)
		end
		d.SetValue = function(_, v)
			pcall(function() d:SetValue(v) end)
		end
		d.Get = function()
			return d.Value
		end
		d.Refresh = function(_, values, keep)
			pcall(function() d:SetValues(values or {}) end)
			if not keep then
				pcall(function() d:SetValue(nil) end)
			end
		end
		return d
	end

	local function ensureFlagObject(flagName, obj)
		if type(flagName) == "string" and flagName ~= "" and obj ~= nil then
			OrionLib.Flags[flagName] = obj
		end
	end

	local function makeNoopSectionProxy()
		local noop = {}
		setmetatable(noop, {
			__index = function(_, k)
				if type(k) == "string" and k:sub(1, 3) == "Add" then
					return function() return noop end
				end
				return nil
			end,
		})
		return noop
	end

	local function makeSectionProxy(tabProxy, grp)
		local section = {}

		function section:AddToggle(ti)
			local t = grp:AddToggle(ti.Name or "Toggle", {
				Text = ti.Name or "Toggle",
				Default = ti.Default == true,
				Callback = ti.Callback,
			})
			local proxy = makeToggleProxy(t)
			ensureFlagObject(ti and ti.Flag, proxy)
			return proxy
		end

		function section:AddButton(ti)
			grp:AddButton(ti.Name or "Button", {
				Text = ti.Name or "Button",
				Func = ti.Callback or ti.Func,
			})
		end

		function section:AddDropdown(ti)
			local multi = (ti and ((ti.MultipleSelection == true) or (ti.Multi == true)))
			local d = grp:AddDropdown(ti.Name or "Dropdown", {
				Text = ti.Name or "Dropdown",
				Values = ti.Options or {},
				Default = ti.Default,
				Multi = multi,
				Callback = ti.Callback,
			})
			d = makeDropdownProxy(d)
			ensureFlagObject(ti and ti.Flag, d)
			return d
		end

		function section:AddTeamsDropdown(ti)
			local multi = (ti and ((ti.MultipleSelection == true) or (ti.Multi == true)))
			local d = grp:AddDropdown(ti.Name or "Teams", {
				Text = ti.Name or "Teams",
				SpecialType = "Team",
				Multi = multi,
				Default = ti and ti.Default or nil,
				Callback = function(val)
					if not ti or not ti.Callback then return end
					if multi and type(val) == "table" then
						local out = {}
						for name, enabled in pairs(val) do
							if enabled then
								table.insert(out, name)
							end
						end
						ti.Callback(out)
					else
						ti.Callback(val)
					end
				end,
			})
			d = makeDropdownProxy(d)
			ensureFlagObject(ti and ti.Flag, d)
			return d
		end

		function section:AddColorpicker(ti)
			local name = (ti and ti.Name) or "Color"
			local flag = ti and ti.Flag
			local default = (ti and ti.Default) or Color3.new(1, 1, 1)

			-- Obsidian exposes ColorPicker as an addon (BaseAddons) attached to a toggle.
			-- We create an inert toggle to host the color picker so sigma code remains compatible.
			local host = grp:AddToggle("__cp_" .. tostring(name), {
				Text = tostring(name),
				Default = false,
				Callback = function() end,
			})
			local cp = host:AddColorPicker("__cp_val_" .. tostring(flag or name), {
				Title = tostring(name),
				Default = default,
				Callback = function(c)
					if ti and ti.Callback then
						ti.Callback(c)
					end
				end,
			})
			ensureFlagObject(flag, cp)
			return cp
		end
		section.AddColorPicker = section.AddColorpicker

		function section:AddSubSection(ti)
			return tabProxy:AddSection(ti)
		end

		function section:AddPlayersDropdown(ti)
			local multi = (ti and ((ti.MultipleSelection == true) or (ti.Multi == true)))
			local d = grp:AddDropdown(ti.Name or "Players", {
				Text = ti.Name or "Players",
				SpecialType = "Player",
				ExcludeLocalPlayer = ti and (ti.ExcludeLocalPlayer == true or ti.RemoveDP == true),
				Multi = multi,
				Default = ti and ti.Default or nil,
				Callback = function(val)
					if not ti or not ti.Callback then return end
					if multi and type(val) == "table" then
						local out = {}
						for name, enabled in pairs(val) do
							if enabled then
								table.insert(out, name)
							end
						end
						ti.Callback(out)
					else
						ti.Callback(val)
					end
				end,
			})
			d = makeDropdownProxy(d)
			ensureFlagObject(ti and ti.Flag, d)
			return d
		end

		function section:AddSlider(ti)
			local s = grp:AddSlider(ti.Name or "Slider", {
				Text = ti.Name or "Slider",
				Min = tonumber(ti.Min) or 0,
				Max = tonumber(ti.Max) or 100,
				Default = tonumber(ti.Default) or tonumber(ti.Min) or 0,
				Rounding = 0,
				Callback = ti.Callback,
			})
			pcall(function()
				if type(s) == "table" and s.Set == nil and s.SetValue ~= nil then
					s.Set = function(_, v) s:SetValue(v) end
				end
			end)
			ensureFlagObject(ti and ti.Flag, s)
			return s
		end

		function section:AddTextbox(ti)
			local i = grp:AddInput(ti.Name or "Textbox", {
				Text = ti.Name or "Textbox",
				Default = tostring(ti.Default or ""),
				Numeric = false,
				Finished = true,
				Callback = ti.Callback,
			})
			pcall(function()
				if type(i) == "table" and i.Set == nil and i.SetValue ~= nil then
					i.Set = function(_, v) i:SetValue(v) end
				end
			end)
			ensureFlagObject(ti and ti.Flag, i)
			return i
		end

		function section:AddLabel(text)
			local lbl = grp:AddLabel(tostring(text or ""))
			return makeLabelProxy(lbl)
		end

		function section:AddBind(ti)
			local kp = grp:AddKeyPicker(ti.Name or "Bind", {
				Text = ti.Name or "Bind",
				Default = ti.Default,
				Mode = ti.Hold and "Hold" or "Toggle",
				Callback = ti.Callback,
			})
			pcall(function()
				if type(kp) == "table" and kp.Set == nil and kp.SetValue ~= nil then
					kp.Set = function(_, v) kp:SetValue(v) end
				end
			end)
			ensureFlagObject(ti and ti.Flag, kp)
			return kp
		end

		function section:AddSection(ti)
			return tabProxy:AddSection(ti)
		end

		function section:AddParagraph(ti)
			local title = (ti and ti.Name) or (ti and ti.Title) or ""
			local content = (ti and ti.Content) or (ti and ti.Description) or ""
			if title ~= "" then
				grp:AddLabel(tostring(title))
			end
			if content ~= "" then
				grp:AddLabel(tostring(content))
			end
			return {}
		end

		return section
	end

	function OrionLib:MakeWindow(info)
		local obsidianWindow = Library:CreateWindow({
			Title = tostring(info and info.Name or "Window"),
			Footer = tostring(info and info.IntroText or ""),
			NotifySide = "Right",
			ShowCustomCursor = true,
		})

		local windowProxy = {}
		function windowProxy:MakeTab(tabInfo)
			local tabName = tostring(tabInfo and tabInfo.Name or "Tab")
			local obsidianTab = obsidianWindow:AddTab(tabName, "box")
			local tabProxy = {
				_tab = obsidianTab,
				_name = tabName,
				_side = 1,
				_currentGroup = nil,
			}
			setmetatable(tabProxy, {
				__index = function(t, k)
					if type(k) == "string" and k:sub(1, 3) == "Add" then
						return function() return makeNoopSectionProxy() end
					end
					return rawget(t, k)
				end,
			})

			function tabProxy:AddToggle(ti)
				local grp = getGroup(tabProxy)
				local t = grp:AddToggle(ti.Name or "Toggle", {
					Text = ti.Name or "Toggle",
					Default = ti.Default == true,
					Callback = ti.Callback,
				})
				local proxy = makeToggleProxy(t)
				ensureFlagObject(ti and ti.Flag, proxy)
				return proxy
			end

			function tabProxy:AddButton(ti)
				local grp = getGroup(tabProxy)
				grp:AddButton(ti.Name or "Button", {
					Text = ti.Name or "Button",
					Func = ti.Callback or ti.Func,
				})
			end

			function tabProxy:AddDropdown(ti)
				local grp = getGroup(tabProxy)
				local multi = (ti and ((ti.MultipleSelection == true) or (ti.Multi == true)))
				local d = grp:AddDropdown(ti.Name or "Dropdown", {
					Text = ti.Name or "Dropdown",
					Values = ti.Options or {},
					Default = ti.Default,
					Multi = multi,
					Callback = ti.Callback,
				})
				d = makeDropdownProxy(d)
				ensureFlagObject(ti and ti.Flag, d)
				return d
			end

			function tabProxy:AddTeamsDropdown(ti)
				local grp = getGroup(tabProxy)
				local multi = (ti and ((ti.MultipleSelection == true) or (ti.Multi == true)))
				local d = grp:AddDropdown(ti.Name or "Teams", {
					Text = ti.Name or "Teams",
					SpecialType = "Team",
					Multi = multi,
					Default = ti and ti.Default or nil,
					Callback = function(val)
						if not ti or not ti.Callback then return end
						if multi and type(val) == "table" then
							local out = {}
							for name, enabled in pairs(val) do
								if enabled then
									table.insert(out, name)
								end
							end
							ti.Callback(out)
						else
							ti.Callback(val)
						end
					end,
				})
				d = makeDropdownProxy(d)
				ensureFlagObject(ti and ti.Flag, d)
				return d
			end

			function tabProxy:AddColorpicker(ti)
				local grp = getGroup(tabProxy)
				return makeSectionProxy(tabProxy, grp):AddColorpicker(ti)
			end
			tabProxy.AddColorPicker = tabProxy.AddColorpicker

			function tabProxy:AddSubSection(ti)
				return tabProxy:AddSection(ti)
			end

			function tabProxy:AddPlayersDropdown(ti)
				local grp = getGroup(tabProxy)
				local multi = (ti and ((ti.MultipleSelection == true) or (ti.Multi == true)))
				local d = grp:AddDropdown(ti.Name or "Players", {
					Text = ti.Name or "Players",
					SpecialType = "Player",
					ExcludeLocalPlayer = ti and (ti.ExcludeLocalPlayer == true or ti.RemoveDP == true),
					Multi = multi,
					Default = ti and ti.Default or nil,
					Callback = function(val)
						if not ti or not ti.Callback then return end
						if multi and type(val) == "table" then
							local out = {}
							for name, enabled in pairs(val) do
								if enabled then
									table.insert(out, name)
								end
							end
							ti.Callback(out)
						else
							ti.Callback(val)
						end
					end,
				})
				d = makeDropdownProxy(d)
				ensureFlagObject(ti and ti.Flag, d)
				return d
			end

			function tabProxy:AddSlider(ti)
				local grp = getGroup(tabProxy)
				local s = grp:AddSlider(ti.Name or "Slider", {
					Text = ti.Name or "Slider",
					Min = tonumber(ti.Min) or 0,
					Max = tonumber(ti.Max) or 100,
					Default = tonumber(ti.Default) or tonumber(ti.Min) or 0,
					Rounding = 0,
					Callback = ti.Callback,
				})
				pcall(function()
					if type(s) == "table" and s.Set == nil and s.SetValue ~= nil then
						s.Set = function(_, v) s:SetValue(v) end
					end
				end)
				ensureFlagObject(ti and ti.Flag, s)
				return s
			end

			function tabProxy:AddTextbox(ti)
				local grp = getGroup(tabProxy)
				local i = grp:AddInput(ti.Name or "Textbox", {
					Text = ti.Name or "Textbox",
					Default = tostring(ti.Default or ""),
					Numeric = false,
					Finished = true,
					Callback = ti.Callback,
				})
				pcall(function()
					if type(i) == "table" and i.Set == nil and i.SetValue ~= nil then
						i.Set = function(_, v) i:SetValue(v) end
					end
				end)
				ensureFlagObject(ti and ti.Flag, i)
				return i
			end

			function tabProxy:AddLabel(text)
				local grp = getGroup(tabProxy)
				local lbl = grp:AddLabel(tostring(text or ""))
				return makeLabelProxy(lbl)
			end

			function tabProxy:AddBind(ti)
				local grp = getGroup(tabProxy)
				local kp = grp:AddKeyPicker(ti.Name or "Bind", {
					Text = ti.Name or "Bind",
					Default = ti.Default,
					Mode = ti.Hold and "Hold" or "Toggle",
					Callback = ti.Callback,
				})
				pcall(function()
					if type(kp) == "table" and kp.Set == nil and kp.SetValue ~= nil then
						kp.Set = function(_, v) kp:SetValue(v) end
					end
				end)
				ensureFlagObject(ti and ti.Flag, kp)
				return kp
			end

			function tabProxy:AddSection(ti)
				local side = tabProxy._side or 1
				local name = (typeof(ti) == "table" and ti.Name) or tostring(ti or "")
				if not name or name == "" then
					name = (tabProxy._name or "Tab") .. " Section"
				end
				local grp = (side == 1) and tabProxy._tab:AddLeftGroupbox(name) or tabProxy._tab:AddRightGroupbox(name)
				tabProxy._side = (side == 1) and 2 or 1
				tabProxy._currentGroup = grp
				return makeSectionProxy(tabProxy, grp)
			end

			function tabProxy:AddParagraph(ti)
				local grp = getGroup(tabProxy)
				local title = (ti and ti.Name) or (ti and ti.Title) or ""
				local content = (ti and ti.Content) or (ti and ti.Description) or ""
				if title ~= "" then
					grp:AddLabel(tostring(title))
				end
				if content ~= "" then
					grp:AddLabel(tostring(content))
				end
				return {}
			end

			return tabProxy
		end

		return windowProxy
	end
end

