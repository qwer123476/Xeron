local allowedURLs = {
    'raw.githubusercontent.com/사용자이름/저장소/main/loader.lua', -- 로더 주소
    -- 'rayfield.dev', 
}

local function isAllowed(url)
    if type(url) ~= 'string' then return false end
    local lowerUrl = string.lower(url)
    
    for _, v in ipairs(allowedURLs) do
                if string.find(lowerUrl, string.lower(v), 1, true) then 
            return true 
        end
    end
    return false
end

local env = getgenv and getgenv() or _G
local httpFuncs = {
    env.request, 
    env.http_request, 
    (env.http and env.http.request), 
    (env.syn and env.syn.request), 
    (env.fluxus and env.fluxus.request)
}

for _, f in pairs(httpFuncs) do
    if type(f) == 'function' then
        local g
        g = hookfunction(f, newcclosure(function(h, ...)
            local url = (type(h) == 'table' and h.Url) or (type(h) == 'string' and h) or "알수없는URL"
            
            if not isAllowed(url) then
                warn('[화이트리스트 차단] 허용되지 않은 외부 요청 차단: ' .. tostring(url))
                -- 403 Forbidden 응답을 반환하여 스크립트가 에러로 튕기지 않고 실패 처리되도록 유도
                return {Success = false, StatusCode = 403, StatusMessage = 'Forbidden', Headers = {}, Body = 'Access Denied'}
            end
            return g(h, ...)
        end))
    end
end

local HttpService = game:GetService('HttpService')
local mt = getrawmetatable(game)
if mt then
    setreadonly(mt, false)
    local oldNamecall = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        

        if self == HttpService and (method == 'PostAsync' or method == 'GetAsync' or method == 'RequestAsync') then
            local url = (type(args[1]) == 'table' and args[1].Url) or (type(args[1]) == 'string' and args[1]) or "알수없는URL"
            
            if not isAllowed(url) then
                warn('[화이트리스트 차단] HttpService 요청 차단: ' .. tostring(url))
                if method == 'PostAsync' or method == 'GetAsync' then
                    return '' 
                else
                    return {Success = false, StatusCode = 403, StatusMessage = 'Forbidden', Headers = {}, Body = 'Access Denied'}
                end
            end
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)
end

print('지정된 로더 외 모든 HTTP 통신 차단 감시 시작 (화이트리스트 활성화)')


local blockedKeywords = {'discord.com/api/webhooks','discordapp.com/api/webhooks','webhook','api.telegram.org','guilded.gg/api/webhooks','hooks.hyra.io','webhook.lewisakura.moe','webhook.pm'}

local function isBlocked(url)
    if type(url) ~= 'string' then return false end
    local lowerUrl = string.lower(url)
    for _, v in ipairs(blockedKeywords) do
        if string.find(lowerUrl, v) then return true end
    end
    return false
end

local env = getgenv and getgenv() or _G
local httpFuncs = {env.request, env.http_request, (env.http and env.http.request), (env.syn and env.syn.request), (env.fluxus and env.fluxus.request)}

for _, f in pairs(httpFuncs) do
    if type(f) == 'function' then
        local g
        g = hookfunction(f, newcclosure(function(h, ...)
            local url = (type(h) == 'table' and h.Url) or (type(h) == 'string' and h) or "알수없는URL"
            if isBlocked(url) then
                warn('[차단 로그] 차단된 URL 발견: ' .. tostring(url))
                return {Success = false, StatusCode = 403, StatusMessage = 'Forbidden', Headers = {}, Body = 'Webhook Blocked'}
            end
            return g(h, ...)
        end))
    end
end

local HttpService = game:GetService('HttpService')
local mt = getrawmetatable(game)
if mt then
    setreadonly(mt, false)
    local oldNamecall = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if self == HttpService and (method == 'PostAsync' or method == 'RequestAsync') then
            local url = (type(args[1]) == 'table' and args[1].Url) or (type(args[1]) == 'string' and args[1]) or "알수없는URL"
            if isBlocked(url) then
                warn('[차단 로그] HttpService에서 차단됨: ' .. tostring(url))
                return (method == 'PostAsync' and '') or {Success = false, StatusCode = 403, StatusMessage = 'Forbidden', Headers = {}, Body = 'Webhook Blocked'}
            end
        end
        return oldNamecall(self, ...)
    end)
    setreadonly(mt, true)
end

