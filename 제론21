    task.spawn(function()
        while true do
            if not enabled then waitExact(1) continue end

            local s = getSlot()
            local h = s and s:FindFirstChild("Handle",true)
            local t = s and getTime(s)

            if h and t and HRP then
                while t.Text ~= "0:00" and enabled do
                    label:Set("Time: "..t.Text)
                    waitExact(0.3)
                end

                if not enabled then continue end

                returnPos = HRP.CFrame

                HRP.CFrame = CFrame.new(h.Position + Vector3.new(0,-3,0))
                waitExact(0.5)
                HRP.Anchored = true
                waitExact(0.5)

                ReplicatedStorage:WaitForChild("GrabEvents"):WaitForChild("SetNetworkOwner"):FireServer(h,CFrame.new(h.Position))

                waitExact(0.8)
                HRP.Anchored = false

                waitExact(1)

                if returnPos then
                    HRP.CFrame = returnPos
                    returnPos = nil
                end
            else
                label:Set("Time: ...")
                waitExact(0.5)
            end
        end
    end)
end
