local AL = getgenv()._AntiLagScript
AL.charBeamMove = plr:WaitForChild("PlayerScripts"):WaitForChild("CharacterAndBeamMove", 5)

local function UpdateCharBeamState()
    if not AL.charBeamMove then return end

    if not AL.antiLagEnabled then
        AL.charBeamMove.Enabled = true
        return
    end

    if not AL.antiLagMode then
        AL.charBeamMove.Enabled = false
        return
    end

    if AL.isLagging or AL.isFpsLow then
        AL.charBeamMove.Enabled = false
    else
        AL.charBeamMove.Enabled = true
    end
end

local function FlagPlayer(fromPlr)
    local data = AL.fireCount[fromPlr]
    if not data then return end
    if data.isFlagged then return end

    data.isFlagged = true

    if not AL.isLagging then
        AL.isLagging = true
        AL.suspectPlayer = fromPlr

        UpdateCharBeamState()

        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "[ 렉 감지 ]",
                Text = fromPlr.Name .. " [ " .. fromPlr.DisplayName .. " ]",
                Duration = 5
            })
        end)
    else
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = "[ 추가 렉 감지 ]",
                Text = fromPlr.Name .. " [ " .. fromPlr.DisplayName .. " ]",
                Duration = 3
            })
        end)
    end
end

AL.renderConnection = RunService.RenderStepped:Connect(function()
    AL.globalFrame += 1

    for plrRef, resetFrame in pairs(AL.pendingResetFrame) do
        if resetFrame < AL.globalFrame then
            local data = AL.fireCount[plrRef]
            if data then
                data.frameBurst = 0
            end
            AL.pendingResetFrame[plrRef] = nil
        end
    end
end)

AL.loopConnection = task.spawn(function()
    local frames = 0
    local frameCounter = RunService.RenderStepped:Connect(function()
        if AL.antiLagEnabled then
            frames += 1
        end
    end)

    while AL.antiLagEnabled do
        task.wait(1)
        local currentFPS = frames
        frames = 0
        
        local anyLagging = false

        for fromPlr, data in pairs(AL.fireCount) do
            data.cps = data.count
            data.count = 0
            
            if data.isFlagged then
                if data.cps <= 10 then
                    data.isFlagged = false
                else
                    anyLagging = true
                    AL.suspectPlayer = fromPlr
                end
            end
        end

        AL.isLagging = anyLagging
        if not AL.isLagging then
            AL.suspectPlayer = nil
        end

        if currentFPS < AL.MinFPS then
            if not AL.isFpsLow then
                AL.isFpsLow = true
                UpdateCharBeamState()
            end
        else
            AL.isFpsLow = false
        end
    end
    
    frameCounter:Disconnect()
end)

local function AntiLagF()
    if AL.connection then
        AL.connection:Disconnect()
        AL.connection = nil
    end

    UpdateCharBeamState()

    AL.connection = Pline:Connect(function(fromPlr, ...)
        if typeof(fromPlr) ~= "Instance" or not fromPlr:IsA("Player") then return end
        if fromPlr == plr then return end

        if not AL.antiLagEnabled or not AL.antiLagMode then return end

        if not AL.fireCount[fromPlr] then
            AL.fireCount[fromPlr] = {
                count = 0,
                cps = 0,
                lastCallTime = 0,
                isFlagged = false,
                lastFrame = 0,
                frameBurst = 0,
                rapidWindowStart = 0,
                rapidCount = 0
            }
        end

        local data = AL.fireCount[fromPlr]
        local currentTime = os.clock()

        if data.lastFrame == AL.globalFrame then
            data.frameBurst += 1

            if data.frameBurst >= AL.FrameBurstLimit then
                FlagPlayer(fromPlr)
            end
        else
            data.lastFrame = AL.globalFrame
            data.frameBurst = 1
            AL.pendingResetFrame[fromPlr] = AL.globalFrame
        end

        if currentTime - data.rapidWindowStart > AL.RapidWindow then
            data.rapidWindowStart = currentTime
            data.rapidCount = 1
        else
            data.rapidCount += 1

            if data.rapidCount >= AL.RapidLimit then
                FlagPlayer(fromPlr)
            end
        end

        if data.lastCallTime ~= 0 and (currentTime - data.lastCallTime) <= 0.025 then
            data.count = AL.AntiLagV
        end

        data.lastCallTime = currentTime
        data.count += 1

        if data.count >= AL.AntiLagV then
            FlagPlayer(fromPlr)
        end
    end)
end

AntiLagF()

