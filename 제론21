local function SaveAll()
    local saveTable = {}

    
    for flag, obj in pairs(OrionLib.Flags or {}) do
        if obj and obj.Value ~= nil then
            saveTable[flag] = obj.Value
        end
    end

    local success, err = pcall(function()
        writefile(FILE, HttpService:JSONEncode(saveTable))
    end)

    if not success then
        warn("SAVE ERROR:", err)
    end
end


local function LoadAll()
    if not isfile(FILE) then return end

    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(FILE))
    end)

    if success and type(data) == "table" then
        for flag, value in pairs(data) do
            if OrionLib.Flags and OrionLib.Flags[flag] then
                pcall(function()
                    OrionLib.Flags[flag]:Set(value)
                end)
            end
        end
    end
end






